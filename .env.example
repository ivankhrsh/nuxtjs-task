# Auth0 tenant domain — found in Auth0 Dashboard → Applications → your app → Domain
NUXT_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 application credentials — Settings tab of your Auth0 application
NUXT_AUTH0_CLIENT_ID=your-client-id
NUXT_AUTH0_CLIENT_SECRET=your-client-secret

# Random secret used to encrypt the session cookie — min 32 characters
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_AUTH0_SESSION_SECRET=replace-with-32-char-random-string

# Base URL of this app — used by Auth0 to build the callback redirect URL
# Dev: http://localhost:3000  |  Prod: https://yourdomain.com
NUXT_AUTH0_APP_BASE_URL=http://localhost:3000
